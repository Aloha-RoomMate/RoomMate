rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // users 컬렉션은 기존과 동일
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    // ✅ posts 컬렉션 규칙 전체를 아래 내용으로 교체하세요.
    match /roomOwnerPosts/{postId} {
    
      // 누구나 게시글을 읽을 수 있도록 허용
      allow read: if true;

      // 게시글 생성(create) 규칙
      allow create: if
        // 1. 반드시 로그인해야 하고,
        request.auth != null &&
        // 2. (핵심) 생성하려는 게시글의 'authorId'가 현재 로그인한 나의 ID와 일치해야 합니다.
        //    (다른 사람 이름으로 글을 쓰는 것을 방지)
        request.resource.data.authorId == request.auth.uid &&
        // 3. title은 비어있지 않은 문자열이어야 합니다.
        request.resource.data.title is string && request.resource.data.title.size() > 0 &&
        // 4. addr은 반드시 GeoPoint(latlng) 타입이어야 합니다.
        request.resource.data.addr is latlng &&
        // 5. introduction은 문자열이어야 합니다.
        request.resource.data.introduction is string;
        // ... 필요한 다른 필드들의 타입도 이런 식으로 추가할 수 있습니다.

      // 게시글 수정(update) 규칙
      allow update: if
        // 1. 반드시 로그인해야 하고,
        request.auth != null &&
        // 2. (핵심) 수정하려는 게시글의 기존 작성자 ID(resource.data.authorId)가
        //    현재 로그인한 나의 ID와 일치해야 합니다. (남의 글 수정을 방지)
        resource.data.authorId == request.auth.uid;
        
      // 게시글 삭제(delete) 규칙
      allow delete: if
        request.auth != null &&
        resource.data.authorId == request.auth.uid;
    }
  }
}